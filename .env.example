# Template for the single ENV_FILE. Its filled-in content is stored whole as the
# `ENV_FILE` GitHub secret; .github/workflows/deploy.yml writes it to .env on the
# home server, where docker-compose reads it via `env_file` and the migration step
# sources it. Locally: copy to .env and fill in.

# Postgres connection string (existing instance — not managed by this repo's compose file)
DATABASE_URL=postgres://user:password@localhost:5432/job_portal

# Redis connection string (existing instance — not managed by this repo's compose file)
REDIS_URL=redis://localhost:6379

# OpenRouter API key used by the LLM enrichment pipeline
OPENROUTER_API_KEY=

# Static bearer token required on all API routes except /health.
# n8n sends this as `Authorization: Bearer <token>` — same value in its Set Config.
API_BEARER_TOKEN=change-me

# pino log level: debug | info | warn | error
LOG_LEVEL=info

# development | test | production
NODE_ENV=development
